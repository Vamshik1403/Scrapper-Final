# =============================================================================
# GarageLeadsPro — Environment Variables TEMPLATE
# =============================================================================
# Copy this file to .env and fill in your real values.
# =============================================================================

# Flask
SECRET_KEY=change-me-to-a-strong-random-string
FLASK_ENV=development

# Database (leave empty for local SQLite fallback)
# On Render: set DATABASE_URL to the Internal Database URL from your PostgreSQL instance
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# API Keys
# Single key:
SERPAPI_KEY=your_serpapi_key_here
# Multiple keys (comma-separated) for automatic rotation when one is exhausted:
# SERPAPI_KEY=key1,key2,key3
# Or numbered:
# SERPAPI_KEY_2=your_second_serpapi_key
# SERPAPI_KEY_3=your_third_serpapi_key

OPENAI_KEY=your_openai_api_key_here
# OPENAI_KEY_2=your_second_openai_key

# Your Info (used in outreach emails / PDFs)
YOUR_EMAIL=your@email.com
YOUR_WEBSITE=yourwebsite.com

# SMTP Settings (for sending outreach emails)
# Gmail: smtp.gmail.com / 587 / use App Password
# Outlook: smtp.office365.com / 587
# Zoho (recommended): smtp.zoho.com / 587 / use App Password
#   → Zoho App Password: Mail → Settings → Security → App Passwords
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_PASSWORD=your_app_password_here
